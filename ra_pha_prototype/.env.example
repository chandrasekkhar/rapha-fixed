# =============================================
# REQUIRED - ఇవి లేకుండా app start కాదు
# =============================================

# Railway లో MySQL database create చేస్తే automatically వస్తుంది
DATABASE_URL=mysql://user:password@host:port/database

# ఏదైనా random string పెట్టండి (e.g., openssl rand -base64 32)
JWT_SECRET=your-random-secret-key-here

# =============================================
# OPTIONAL - ఈ features demo లో పని చేయవు
# కానీ app crash కాదు
# =============================================

# Razorpay payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMS (Exotel/Twilio)
SMS_API_KEY=
SMS_API_SECRET=

# Firebase push notifications
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# AI features (Anthropic/OpenAI)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
